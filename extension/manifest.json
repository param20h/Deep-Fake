{
  "manifest_version": 3,
  "name": "DeepFake Detector",
  "version": "1.0",
  "description": "Detect AI-generated faces in images instantly.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeepFake Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ]
}
